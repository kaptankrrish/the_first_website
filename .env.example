# =============================================================================
# AI Knowledge Ecosystem - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All variables are optional — the app runs without them using built-in fallbacks.

# -----------------------------------------------------------------------------
# Google AdSense
# -----------------------------------------------------------------------------
# Your Google AdSense publisher/client ID (e.g. ca-pub-XXXXXXXXXXXXXXXX).
# Enables ad integration in the layout. If not set, the AdSense script is not loaded.
NEXT_PUBLIC_ADSENSE_ID=

# -----------------------------------------------------------------------------
# NVIDIA API (AI Content Analysis)
# -----------------------------------------------------------------------------
# API key from https://build.nvidia.com/ — used for AI-powered content analysis.
# If not set, AI features return a graceful fallback response.
NVIDIA_API_KEY=

# -----------------------------------------------------------------------------
# TMDB (The Movie Database)
# -----------------------------------------------------------------------------
# API key from https://www.themoviedb.org/settings/api.
# NOTE: The current movie route uses a public IMDb proxy and does not require
# this key, but it is referenced in the README for potential future use.
NEXT_PUBLIC_TMDB_KEY=
